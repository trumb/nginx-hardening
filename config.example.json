{
  "log_files": [
    "/var/log/nginx/your-site-access.log"
  ],
  "hardening_conf": "/etc/nginx/snippets/security-hardening.conf",
  "claw_site_conf": "/etc/nginx/sites-available/your-site.example.com",
  "repo_path": "/home/youruser/nginx-hardening",
  "state_file": "/opt/nginx-hardening/state.json",
  "log_file": "/var/log/nginx-hardening/autoharden.log",
  "honeypot_routes": [
    "/health",
    "/api/",
    "/app/"
  ],
  "whitelisted_paths": [
    "/.well-known/acme-challenge/",
    "/favicon.ico"
  ],
  "whitelisted_ua_patterns": [
    "curl",
    "certbot",
    "Let's Encrypt"
  ],
  "min_occurrences": 3,
  "max_rules_per_run": 10,
  "chrome_min_version": 80
}
